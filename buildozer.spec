[app]
title = Ashraf Flash
package.name = ashraflash
package.domain = org.ashraf
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 0.1
requirements = python3,kivy,plyer
orientation = portrait
fullscreen = 0
android.permissions = CAMERA
android.api = 34
android.minapi = 21
android.sdk = 34
android.ndk = 25c
android.archs = arm64-v8a
android.accept_sdk_license = True

[buildozer]
log_level = 2
warn_on_root = 1
